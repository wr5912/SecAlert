# SecAlert 多源异构数据模拟器环境变量配置
# 复制此文件为 .env.simulators 并根据实际情况修改

# ===========================================
# SecAlert 目标地址配置
# ===========================================

# SecAlert Ingest API 地址 (log-generator HTTP 推送目标)
SECALERT_INGEST_URL=http://localhost:9000/api/v1/ingest

# SecAlert API Token (如果需要认证)
SECALERT_API_TOKEN=test-token

# Syslog 目标地址 (syslog-simulator 发送目标)
SECALERT_SYSLOG_HOST=localhost
SECALERT_SYSLOG_PORT=514
SECALERT_SYSLOG_PROTOCOL=UDP

# ===========================================
# 模拟器参数配置
# ===========================================

# 日志生成速率 (条/秒)
SIMULATOR_RATE=10

# 日志格式: CEF, JSON, SYSLOG
SIMULATOR_FORMAT=CEF

# REST Polling 间隔 (秒)
POLLING_INTERVAL=5

# 文件日志写入间隔 (秒)
FILE_LOG_INTERVAL=2

# 文件日志格式: JSON, SYSLOG, PLAIN
FILE_LOG_FORMAT=JSON

# ===========================================
# 监控配置 (可选)
# ===========================================

# Grafana 密码
# GRAFANA_PASSWORD=admin123
