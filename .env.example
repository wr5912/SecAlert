# Kafka
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC_RAW_SURICATA=raw-suricata
KAFKA_CONSUMER_GROUP_PARSER=parser-suricata

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=secalert
POSTGRES_USER=secalert
POSTGRES_PASSWORD=secalert_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DEDUP_WINDOW=86400

# Elasticsearch
ES_HOST=localhost:9200
ES_PORT=9200
ES_USER=elastic
ES_PASSWORD=changeme
ES_INDEX=security-alerts-*

# Logstash - Elasticsearch Source
LOGSTASH_ENABLED=false

# Vector
VECTOR_API_ADDR=0.0.0.0:9001

# Parser
PARSER_TEMPLATE_DIR=parser/templates
PARSER_DRAIN_CONFIG=parser/drain/config.yaml

# AI/LLM 配置
# 使用 vLLM 本地推理 (Qwen3-32B)
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=Qwen/Qwen3-32B
# VLLM_API_KEY=EMPTY

# 备选：在线模型 (DeepSeek / MiniMax)
# 选择其中一种，注释或删除其他
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# MINIMAX_API_KEY=your-minimax-api-key
# MINIMAX_BASE_URL=https://api.minimax.chat/v1
# MINIMAX_MODEL=abab6.5s-chat

# 当前使用的 LLM 提供者: vllm | deepseek | minimax
LLM_PROVIDER=deepseek